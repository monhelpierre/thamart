rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'monhelmaudoonypierre@gmail.com';
    }

    // Admin gets full access to every document in every collection
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Products are public to read
    match /products/{productId} {
      allow read: if true;
    }

    // Reviews are public to read; any signed-in user can create one
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Users can read and write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Users can read their own orders
    match /orders/{orderId} {
      allow read: if request.auth != null
          && request.auth.uid == resource.data.userId;
    }

    // Carts belong to the owning user
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
